self := import("@platforma-sdk/workflow-tengo:tpl")
text := import("text")

self.defineOutputs("emptyOrNot")

self.body(func(args) {
    content := string(args.content.getData())
    // FASTA has no header line, so empty content means no sequences
    isEmpty := text.trim_space(content) == ""

    result := "notEmpty"
    if isEmpty {
        result = "empty"
    }

    return {
        emptyOrNot: result
    }
})
